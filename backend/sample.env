# Backend runtime configuration

# Monad RPC endpoints
MONAD_NODE1=https://your-node1.example.com:8545
MONAD_NODE2=https://your-node2.example.com:8545
MONAD_NODE3=wss://your-node3.example.com:8546

# Optional runtime tuning
WS_PATH=/ws
METRICS_LOG_INTERVAL_MS=60000
BROADCAST_WINDOW_MS=60000
MAX_IN_MEMORY_BLOCKS=5000
POLL_INTERVAL_MS=3000
MAX_BATCH_SIZE=20
PER_NODE_BLOCK_CONCURRENCY=5
TRACE_CONCURRENCY=10
MAX_QUEUE_SIZE=1000
LAST_BLOCKS_WINDOW=20
MAX_REQUESTS_PER_SECOND_PER_NODE=40
RETRY_MAX_ATTEMPTS=3
RETRY_BASE_BACKOFF_MS=2000
RETRY_MAX_BACKOFF_MS=10000
NODE_DISABLE_MS=30000


